             VALUES ($1, $2, $3, $4, $5) RETURNING *`,
            [patient_id, medecin_id, date_heure, motif, notes]
        );
        res.status(201).json(result.rows[0]);
    } catch (error) {
        res.status(500).json({ error: error.message });
    }
});

